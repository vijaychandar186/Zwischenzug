# ─────────────────────────────────────────────────────────────────────────────
# Zwischenzug CLI — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LiteLLM provider to use.
# Tip: `zwis` setup now shows providers dynamically from LiteLLM.
ZWISCHENZUG_PROVIDER=

# Model identifier or short alias.
# Groq aliases:   gpt-oss, gpt-oss-small, qwen, versatile, fast
# Gemini aliases: pro, flash, flash-lite, pro-2.5, flash-2.5
# OpenAI aliases: large, mini, nano
# The selected provider stays in control. That means namespaced models like
# `openai/gpt-oss-120b` can still be routed through Groq when
# `ZWISCHENZUG_PROVIDER=groq`.
# Tip: `zwis` setup now shows models dynamically for your chosen provider.
ZWISCHENZUG_MODEL=

# ── API Key ───────────────────────────────────────────────────────────────────
# Set the key for your chosen provider. `zwis --init` does this automatically.
# Convention: <PROVIDER>_API_KEY=your_key_here  (e.g. GROQ_API_KEY=)
# Full list: https://docs.litellm.ai/docs/providers

# ── Generation Parameters ─────────────────────────────────────────────────────
ZWISCHENZUG_TEMPERATURE=1
ZWISCHENZUG_MAX_TOKENS=4096
ZWISCHENZUG_MAX_RETRIES=2

# Optional reasoning controls for providers/models that support them.
# Examples:
# ZWISCHENZUG_INCLUDE_REASONING=true
# ZWISCHENZUG_REASONING_EFFORT=medium
# ZWISCHENZUG_REASONING_FORMAT=parsed
# Supported values for reasoning effort in Zwischenzug:
# none | default | low | medium | high
# ZWISCHENZUG_INCLUDE_REASONING=
# ZWISCHENZUG_REASONING_EFFORT=
# ZWISCHENZUG_REASONING_FORMAT=

# ── Streaming ─────────────────────────────────────────────────────────────────
# Enable/disable streaming responses (default: true)
# ZWISCHENZUG_STREAMING=true

# ── Cost Tracking & Budget ────────────────────────────────────────────────────
# USD per 1 million tokens. Check your provider's pricing page for values.
# ZWISCHENZUG_COST_INPUT=0.15
# ZWISCHENZUG_COST_OUTPUT=0.60
# Hard budget cap in USD — session ends when exceeded.
# ZWISCHENZUG_BUDGET=1.00

# ── Session Limits ────────────────────────────────────────────────────────────
# ZWISCHENZUG_MAX_TURNS=50

# ── Permissions ───────────────────────────────────────────────────────────────
# auto        — all tools run without prompting
# interactive — write operations prompt for approval
# deny        — write operations are blocked (read-only / plan mode)
ZWISCHENZUG_PERMISSION=auto

# ── System Prompt Override ────────────────────────────────────────────────────
# Replaces the default system prompt entirely. Leave blank to use the default.
# ZWISCHENZUG_SYSTEM=You are a concise coding assistant.

# ── Memory ───────────────────────────────────────────────────────────────────
# Override the default memory directory (default: ~/.zwis/memory/)
# ZWISCHENZUG_MEMORY_DIR=~/.zwis/memory

# ── Storage ───────────────────────────────────────────────────────────────────
# Override the .zwis/ directory location (default: <cwd>/.zwis/)
# ZWISCHENZUG_HOME=~/.zwis

# ── Animated UI (zwischenzug subcommand) ─────────────────────────────────────
ZWISCHENZUG_MESSAGE=Provide one concise coding action for this task.
